# ── Required ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── OpenRouter settings ───────────────────────────────────────────────────────
# Supported models: google/gemini-2.5-flash | openai/gpt-4o-mini |
#                   anthropic/claude-3.5-haiku | qwen/qwen-2.5-7b-instruct
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=polyglot-voice-agent

# ── Whisper STT ───────────────────────────────────────────────────────────────
# Model sizes: tiny | base | small | medium | large-v2 | large-v3
# "base" is the default — fast, ~74 MB, good for demo.
WHISPER_MODEL_SIZE=base

# ── Piper TTS (optional) ──────────────────────────────────────────────────────
# Leave blank to use browser speechSynthesis fallback.
# Download .onnx voice files from:
#   https://github.com/rhasspy/piper/releases/tag/v1.2.0
# Place them in polyglot-voice-agent/voices/ (or any path you prefer).
PIPER_EXECUTABLE=piper
PIPER_VOICE_PATH_EN=voices/en_US-lessac-medium.onnx
PIPER_VOICE_PATH_HI=voices/hi_IN-deepika-medium.onnx
PIPER_VOICE_PATH_ES=voices/es_ES-sharvard-medium.onnx

# ── Mock mode overrides (for testing without hardware/models) ─────────────────
USE_MOCK_STT=false
USE_MOCK_LLM=false
USE_MOCK_TTS=false
